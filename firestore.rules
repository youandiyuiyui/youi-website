rules_version = '2';

// You&i Space — Firestore セキュリティルール
// ※ このファイルは記録用。実際の反映は Firebase コンソール
//   （プロジェクト you-i-space → Firestore Database → ルール）に
//   丸ごと貼り付けて「公開」してください。

service cloud.firestore {
  match /databases/{database}/documents {

    // ── ユーザープロフィール ──
    // ログイン者は閲覧可。作成・編集は本人のみ。
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // ── 支援・受援の投稿 ──
    // ログイン者は全員閲覧可（他アカウントの投稿も見える）。
    // 作成・編集（修正）・削除は投稿者本人のみ。
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;
    }

    // ── 会話（メッセージスレッド）──
    // 参加者（participants に含まれる2人）だけが閲覧・作成・更新できる。
    match /conversations/{cid} {
      allow read:   if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    && request.auth.uid in request.resource.data.participants;

      // ── 個々のメッセージ ──
      // 会話の参加者のみ閲覧。送信は本人（senderId==自分）かつ参加者のみ。
      match /messages/{mid} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participants;
      }
    }
  }
}
